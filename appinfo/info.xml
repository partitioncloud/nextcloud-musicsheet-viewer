<?xml version="1.0"?>
<info xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="https://apps.nextcloud.com/schema/apps/info.xsd">
	<id>musicsheetviewer</id>
	<name>MusicSheet Viewer</name>
	<summary>Visualize and play music sheets</summary>
	<description>Visualize and play music sheets of various formats

- mscz, mscx | MuseScore
- mxl, musicxml | MusicXML
- gp, gp3, ... | GuitarPro
- and many more, see [MuseScore handbook for full list](https://musescore.org/en/handbook/3/file-formats#share-with-other-software) for untested formats.
</description>
	<version>1.2.4</version>
	<licence>AGPL-3.0-or-later</licence>
	<author mail="me.git@augustin64.fr" homepage="https://github.com/augustin64/">Augustin64</author>
	<namespace>MusicSheetViewer</namespace>
	<category>files</category>
	<category>multimedia</category>
	<bugs>https://github.com/partitioncloud/nextcloud-musicsheet-viewer/issues</bugs>
	<website>https://github.com/partitioncloud/nextcloud-musicsheet-viewer</website>
	<screenshot>https://raw.githubusercontent.com/partitioncloud/nextcloud-musicsheet-viewer/main/src/img/screenshot.png</screenshot>
	<screenshot small-thumbnail="https://raw.githubusercontent.com/partitioncloud/nextcloud-musicsheet-viewer/main/src/img/screenshot-small.png">https://raw.githubusercontent.com/partitioncloud/nextcloud-musicsheet-viewer/main/src/img/screenshot-small.png</screenshot>

	<dependencies>
		<nextcloud min-version="32" max-version="34"/>
	</dependencies>
	<repair-steps>
		<install>
			<step>OCA\MusicSheetViewer\Migration\MimeTypeInstall</step>
		</install>
		<uninstall>
			<step>OCA\MusicSheetViewer\Migration\MimeTypeUninstall</step>
		</uninstall>
	</repair-steps>
</info>
